<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Real Estate"
            android:textSize="32sp"
            android:textColor="#00d4ff"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Property Price Predictor"
            android:textSize="16sp"
            android:textColor="#a0a0a0"
            android:textAlignment="center"
            android:layout_marginBottom="40dp" />

        <!-- Input Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#252542"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Property Details"
                    android:textSize="20sp"
                    android:textColor="#ffffff"
                    android:textStyle="bold"
                    android:layout_marginBottom="24dp" />

                <!-- Bedrooms -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bedrooms"
                    android:textColor="#a0a0a0"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etBedrooms"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/edit_text_background"
                    android:hint="e.g., 3"
                    android:textColorHint="#666666"
                    android:textColor="#ffffff"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp" />

                <!-- Bathrooms -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bathrooms"
                    android:textColor="#a0a0a0"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etBathrooms"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/edit_text_background"
                    android:hint="e.g., 2"
                    android:textColorHint="#666666"
                    android:textColor="#ffffff"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp" />

                <!-- Square Feet -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Square Feet"
                    android:textColor="#a0a0a0"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etSqft"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/edit_text_background"
                    android:hint="e.g., 1500"
                    android:textColorHint="#666666"
                    android:textColor="#ffffff"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp" />

                <!-- Location Score -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Location Score (1-10)"
                    android:textColor="#a0a0a0"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etLocationScore"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/edit_text_background"
                    android:hint="e.g., 7.5"
                    android:textColorHint="#666666"
                    android:textColor="#ffffff"
                    android:inputType="numberDecimal"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp" />

                <!-- Property Age -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Property Age (years)"
                    android:textColor="#a0a0a0"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etAge"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/edit_text_background"
                    android:hint="e.g., 10"
                    android:textColorHint="#666666"
                    android:textColor="#ffffff"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp" />

                <!-- Predict Button -->
                <Button
                    android:id="@+id/btnPredict"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Get Price Estimate"
                    android:textColor="#1a1a2e"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#00d4ff" />

                <!-- Progress Bar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    android:indeterminateTint="#00d4ff" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Result Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#252542"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvResultLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Estimated Market Value"
                    android:textSize="16sp"
                    android:textColor="#a0a0a0"
                    android:textAlignment="center"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="36sp"
                    android:textColor="#00d4ff"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Powered by Machine Learning"
            android:textSize="12sp"
            android:textColor="#666666"
            android:textAlignment="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
